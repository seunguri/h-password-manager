<Window x:Class="PasswordProtector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Password Protector" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        KeyDown="Window_KeyDown"
        Closing="Window_Closing">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" Text="계정 관리" FontSize="24" FontWeight="Bold" Foreground="#DCDCDC"/>
            
            <Button Grid.Column="1" Content="+ 새 계정" Click="AddButton_Click"
                    Background="#007ACC" Foreground="White" 
                    Padding="15,8" FontSize="14" BorderThickness="0"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1C97EA"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
        
        <!-- Search Box -->
        <TextBox x:Name="SearchTextBox" Grid.Row="1" 
                 TextChanged="SearchTextBox_TextChanged"
                 KeyDown="SearchTextBox_KeyDown"
                 Background="#2D2D30" Foreground="#DCDCDC" 
                 BorderBrush="#3F3F46" BorderThickness="1"
                 Padding="10,8" FontSize="14" Margin="0,0,0,15">
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TextBox">
                                <Border Background="{TemplateBinding Background}" 
                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="4">
                                    <Grid>
                                        <TextBlock x:Name="PlaceholderText" 
                                                   Text="검색... (서비스명, 아이디, 태그, 비고)"
                                                   Foreground="#808080" 
                                                   Padding="{TemplateBinding Padding}"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TextBox.Style>
        </TextBox>
        
        <!-- Tag Filters -->
        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,15">
            <ItemsControl x:Name="TagFilterControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2D2D30" CornerRadius="12" Padding="12,6" Margin="0,0,8,0" 
                                Cursor="Hand" MouseLeftButtonDown="TagFilter_MouseLeftButtonDown">
                            <TextBlock Text="{Binding}" Foreground="#DCDCDC" FontSize="12"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        <!-- Account Cards -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="AccountCardsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#252526" CornerRadius="6" Padding="20" Margin="0,0,0,12"
                                BorderBrush="#3F3F46" BorderThickness="1"
                                Cursor="Hand" MouseLeftButtonDown="AccountCard_MouseLeftButtonDown">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <!-- Service Name & Status -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding ServiceName}" FontSize="16" FontWeight="Bold" Foreground="#DCDCDC"/>
                                    </StackPanel>
                                    
                                    <!-- Username -->
                                    <TextBlock Text="{Binding Username}" FontSize="14" Foreground="#808080" Margin="0,0,0,8"/>
                                    
                                    <!-- Tags -->
                                    <ItemsControl ItemsSource="{Binding Tags, Converter={StaticResource TagsToListConverter}}" Margin="0,0,0,8">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#007ACC" CornerRadius="10" Padding="8,4" Margin="0,0,6,0">
                                                    <TextBlock Text="{Binding}" Foreground="White" FontSize="11"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    
                                    <!-- Notes -->
                                    <TextBlock Text="{Binding Notes}" FontSize="12" Foreground="#808080" TextWrapping="Wrap"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="👁" Tag="{Binding}" Click="TogglePassword_Click"
                                            Background="Transparent" Foreground="#DCDCDC" BorderThickness="0"
                                            FontSize="16" Padding="8" Margin="0,0,8,0" Cursor="Hand"/>
                                    <Button Content="📋" Tag="{Binding}" Click="CopyPassword_Click"
                                            Background="Transparent" Foreground="#DCDCDC" BorderThickness="0"
                                            FontSize="16" Padding="8" Cursor="Hand"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        <!-- Footer -->
        <TextBlock x:Name="AccountCountText" Grid.Row="4" Text="총 0개의 계정" 
                   Foreground="#808080" FontSize="12" Margin="0,15,0,0" HorizontalAlignment="Center"/>
    </Grid>
</Window>
