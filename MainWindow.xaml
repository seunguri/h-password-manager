<Window x:Class="PasswordProtector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="계정 관리" Height="700" Width="1370"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        KeyDown="Window_KeyDown"
        Closing="Window_Closing">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- 헤더 새로고침·사이드바 보내기 등 공통 테두리 버튼 -->
            <!-- 설정 패널: 체크박스와 같은 줄 높이의 보내기 행 -->
            <Style x:Key="SettingsRowExportButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="ExportGlyphBox"
                                        Width="18" Height="18"
                                        Background="#2D2D30"
                                        BorderBrush="#3F3F46"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Margin="0,0,8,0"
                                        SnapsToDevicePixels="True">
                                    <TextBlock Text="📤"
                                               FontSize="10"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="복호화해서 내보내기"
                                           Foreground="#DCDCDC"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ExportGlyphBox" Property="BorderBrush" Value="#007ACC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ToolbarOutlineButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#2D2D30"/>
                <Setter Property="Foreground" Value="#DCDCDC"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="BorderBrush" Value="#3F3F46"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#3F3F46"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>
        
        <!-- Main Content -->
        <Grid Grid.Column="0" Margin="0,0,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Background="#2D2D30" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                        <TextBlock Text="🔑" FontSize="20"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="계정 관리" FontSize="24" FontWeight="Bold" Foreground="#DCDCDC"/>
                        <TextBlock Text="Account Manager" FontSize="11" Foreground="#808080"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="🔄 새로고침" Click="RefreshDashboard_Click"
                            Style="{StaticResource ToolbarOutlineButtonStyle}"
                            Margin="0,0,8,0"
                            ToolTip="파일에서 계정·태그 목록을 다시 불러옵니다 (F5)"/>
                    <Button Content="+ 새 계정" Click="AddButton_Click"
                            Background="#007ACC" Foreground="White"
                            Padding="15,8" FontSize="14" BorderThickness="0"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1C97EA"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
            
            <!-- Search Box -->
            <TextBox x:Name="SearchTextBox" Grid.Row="1" 
                     TextChanged="SearchTextBox_TextChanged"
                     KeyDown="SearchTextBox_KeyDown"
                     Background="#2D2D30" Foreground="#DCDCDC" 
                     BorderBrush="#3F3F46" BorderThickness="1"
                     Padding="10,8" FontSize="14" Margin="0,0,0,15">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TextBox">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4">
                                        <Grid>
                                            <TextBlock x:Name="PlaceholderText" 
                                                       Text="🔍 서비스명, 아이디, 태그로 검색..."
                                                       Foreground="#808080" 
                                                       Padding="{TemplateBinding Padding}"
                                                       VerticalAlignment="Center"
                                                       IsHitTestVisible="False">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TextBox.Style>
            </TextBox>
            
            <!-- Tag Filters -->
            <Grid Grid.Row="2" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="🔽 태그 필터" Foreground="#DCDCDC" FontSize="12" 
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                
                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="TagFilterControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2D2D30" CornerRadius="12" Padding="12,6" Margin="0,0,8,0" 
                                        Cursor="Hand" MouseLeftButtonDown="TagFilter_MouseLeftButtonDown">
                                    <TextBlock Text="{Binding}" Foreground="#DCDCDC" FontSize="12"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
            
            <!-- Account Cards -->
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="AccountCardsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#252526" CornerRadius="6" Padding="16" Margin="0,0,12,12"
                                    BorderBrush="#3F3F46" BorderThickness="1" Width="320"
                                    Cursor="Hand" MouseLeftButtonDown="AccountCard_MouseLeftButtonDown">
                                <StackPanel>
                                    <!-- Service name row: status + title (ellipsis) | copy + delete -->
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ServiceName}" FontSize="15" FontWeight="Bold" Foreground="#DCDCDC"
                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="📋" Tag="{Binding}" Click="CopyPassword_Click"
                                                    Background="Transparent" Foreground="#DCDCDC" BorderThickness="0"
                                                    FontSize="14" Padding="4" Margin="0,0,2,0" Cursor="Hand"
                                                    ToolTip="비밀번호를 클립보드에 복사">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Foreground" Value="#DCDCDC"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                                <Setter Property="BorderBrush" Value="#1C97EA"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button Content="🗑️" Tag="{Binding}" Click="DeleteAccount_Click"
                                                    Background="Transparent" Foreground="#F48771" BorderThickness="0"
                                                    FontSize="14" Padding="4" Cursor="Hand"
                                                    ToolTip="계정 삭제">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Foreground" Value="#F48771"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                                <Setter Property="BorderBrush" Value="#F48771"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Tags (under service name, 없으면 접음) -->
                                    <ItemsControl ItemsSource="{Binding Tags, Converter={StaticResource TagsToListConverter}}" Margin="0,0,0,8">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasTags}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#007ACC" CornerRadius="10" Padding="8,4" Margin="0,0,6,4">
                                                    <TextBlock Text="{Binding}" Foreground="White" FontSize="11"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Username -->
                                    <TextBlock Text="{Binding Username}" FontSize="13" Foreground="#808080" Margin="0,0,0,6"
                                               Visibility="{Binding Username, Converter={StaticResource StringToVisibilityConverter}}"/>

                                    <TextBlock Text="{Binding CardScheduleSummary}" FontSize="11" Foreground="#808080"
                                               Margin="0,0,0,8" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding CardScheduleSummary}"
                                               Visibility="{Binding CardScheduleSummary, Converter={StaticResource StringToVisibilityConverter}}"/>

                                    <!-- 비고 (내용 있을 때만) -->
                                    <Border Background="#1E1E1E" CornerRadius="4" Padding="8,6" Margin="0,0,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasNotesContent}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding NotesCardBody}" FontSize="11" Foreground="#B0B0B0"
                                                   TextWrapping="Wrap" MaxHeight="56" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Notes}"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- Footer -->
            <TextBlock x:Name="AccountCountText" Grid.Row="4" Text="총 0개의 계정" 
                       Foreground="#808080" FontSize="12" Margin="0,15,0,0" HorizontalAlignment="Left"/>
        </Grid>
        
        <!-- Right Sidebar -->
        <Border Grid.Column="1" Background="#252526" CornerRadius="8" Padding="20">
            <StackPanel>
                <!-- Shortcuts Section -->
                <TextBlock Text="⌨️ 단축키" FontSize="16" FontWeight="Bold" Foreground="#DCDCDC" Margin="0,0,0,15"/>
                
                <StackPanel Margin="0,0,0,20">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#2D2D30" CornerRadius="4" Padding="6,4" Margin="0,0,8,0">
                            <TextBlock Text="Ctrl + N" FontSize="11" Foreground="#DCDCDC" FontFamily="Consolas"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="새 계정 추가" FontSize="12" Foreground="#808080" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#2D2D30" CornerRadius="4" Padding="6,4" Margin="0,0,8,0">
                            <TextBlock Text="Ctrl + F" FontSize="11" Foreground="#DCDCDC" FontFamily="Consolas"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="검색" FontSize="12" Foreground="#808080" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#2D2D30" CornerRadius="4" Padding="6,4" Margin="0,0,8,0">
                            <TextBlock Text="F5" FontSize="11" Foreground="#DCDCDC" FontFamily="Consolas"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="대시보드 새로고침" FontSize="12" Foreground="#808080" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#2D2D30" CornerRadius="4" Padding="6,4" Margin="0,0,8,0">
                            <TextBlock Text="Ctrl + Shift + P" FontSize="11" Foreground="#DCDCDC" FontFamily="Consolas"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="창 열기" FontSize="12" Foreground="#808080" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#2D2D30" CornerRadius="4" Padding="6,4" Margin="0,0,8,0">
                            <TextBlock Text="Esc" FontSize="11" Foreground="#DCDCDC" FontFamily="Consolas"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="닫기 / 취소" FontSize="12" Foreground="#808080" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#2D2D30" CornerRadius="4" Padding="6,4" Margin="0,0,8,0">
                            <TextBlock Text="Enter" FontSize="11" Foreground="#DCDCDC" FontFamily="Consolas"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="저장" FontSize="12" Foreground="#808080" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
                
                <!-- Status Section -->
                <TextBlock Text="📊 상태 표시" FontSize="16" FontWeight="Bold" Foreground="#DCDCDC" Margin="0,0,0,15"/>
                
                <StackPanel  Margin="0,0,0,20">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#4EC9B0" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="정상" FontSize="12" Foreground="#808080"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#CE9178" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="7일 이내 만료" FontSize="12" Foreground="#808080"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#F48771" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="만료 기한 초과" FontSize="12" Foreground="#808080"/>
                    </Grid>
                </StackPanel>

                <!-- 상태표시 밑에 원본파일 위치 정보 추가 -->
                <TextBlock Text="📁 원본파일 위치" FontSize="16" FontWeight="Bold" Foreground="#DCDCDC" Margin="0,0,0,15"/>
                <StackPanel Margin="0,0,0,20">
                    <Border Background="#2D2D30" CornerRadius="4" Padding="8,6" 
                            Cursor="Hand" MouseLeftButtonDown="OpenFilePath_Click">
                        <TextBlock x:Name="FilePathText"
                                   FontSize="11"
                                   Foreground="#3794FF"
                                   TextWrapping="Wrap"
                                   TextDecorations="Underline"
                                   ToolTip="클릭하면 파일 위치를 엽니다"/>
                    </Border>
                    <TextBlock Margin="0,8,0,0"
                               FontSize="11"
                               Foreground="#808080"
                               TextWrapping="Wrap"
                               LineHeight="16"
                               Text="비밀번호는 위 경로의 파일에 평문이 아닌 암호화된 상태로 저장됩니다."/>
                </StackPanel>
                
                <!-- 설정 -->
                <TextBlock Text="⚙️ 설정" FontSize="16" FontWeight="Bold" Foreground="#DCDCDC" Margin="0,0,0,15"/>
                
                <CheckBox x:Name="StartupCheckBox" 
                          Content="Windows 시작 시 자동 실행" 
                          Foreground="#DCDCDC" 
                          FontSize="12"
                          Margin="0,0,0,12"
                          Checked="StartupCheckBox_Checked"
                          Unchecked="StartupCheckBox_Unchecked"
                          Loaded="StartupCheckBox_Loaded">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="CheckBox">
                                        <StackPanel Orientation="Horizontal">
                                            <Border x:Name="CheckBoxBorder" 
                                                    Width="18" Height="18" 
                                                    Background="#2D2D30" 
                                                    BorderBrush="#3F3F46" 
                                                    BorderThickness="1" 
                                                    CornerRadius="3"
                                                    Margin="0,0,8,0">
                                                <TextBlock x:Name="CheckMark" 
                                                           Text="✓" 
                                                           Foreground="#007ACC" 
                                                           FontSize="12" 
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"
                                                           Visibility="Collapsed"/>
                                            </Border>
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#007ACC"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#007ACC"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </CheckBox.Style>
                </CheckBox>

                <Button Click="ExportDecryptedIni_Click"
                        Style="{StaticResource SettingsRowExportButtonStyle}"
                        Margin="0,0,0,8"
                        ToolTip="비밀번호를 평문으로 풀어 INI 파일로 저장합니다."/>
            </StackPanel>            
        </Border>
    </Grid>
</Window>
