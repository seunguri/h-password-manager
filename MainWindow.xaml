<Window x:Class="PasswordProtector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Password Protector" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        KeyDown="Window_KeyDown"
        Closing="Window_Closing">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>
        
        <!-- Main Content -->
        <Grid Grid.Column="0" Margin="0,0,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Background="#2D2D30" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                        <TextBlock Text="🔑" FontSize="20"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="계정 관리" FontSize="24" FontWeight="Bold" Foreground="#DCDCDC"/>
                        <TextBlock Text="Account Manager" FontSize="11" Foreground="#808080"/>
                    </StackPanel>
                </StackPanel>
                
                <Button Grid.Column="1" Content="+ 새 계정" Click="AddButton_Click"
                        Background="#007ACC" Foreground="White" 
                        Padding="15,8" FontSize="14" BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1C97EA"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
            
            <!-- Search Box -->
            <TextBox x:Name="SearchTextBox" Grid.Row="1" 
                     TextChanged="SearchTextBox_TextChanged"
                     KeyDown="SearchTextBox_KeyDown"
                     Background="#2D2D30" Foreground="#DCDCDC" 
                     BorderBrush="#3F3F46" BorderThickness="1"
                     Padding="10,8" FontSize="14" Margin="0,0,0,15">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TextBox">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4">
                                        <Grid>
                                            <TextBlock x:Name="PlaceholderText" 
                                                       Text="🔍 서비스명, 아이디, 태그로 검색..."
                                                       Foreground="#808080" 
                                                       Padding="{TemplateBinding Padding}"
                                                       VerticalAlignment="Center"
                                                       IsHitTestVisible="False">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TextBox.Style>
            </TextBox>
            
            <!-- Tag Filters -->
            <Grid Grid.Row="2" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="🔽 태그 필터" Foreground="#DCDCDC" FontSize="12" 
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                
                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="TagFilterControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#2D2D30" CornerRadius="12" Padding="12,6" Margin="0,0,8,0" 
                                        Cursor="Hand" MouseLeftButtonDown="TagFilter_MouseLeftButtonDown">
                                    <TextBlock Text="{Binding}" Foreground="#DCDCDC" FontSize="12"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
            
            <!-- Account Cards -->
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="AccountCardsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#252526" CornerRadius="6" Padding="16" Margin="0,0,12,12"
                                    BorderBrush="#3F3F46" BorderThickness="1"
                                    Cursor="Hand" MouseLeftButtonDown="AccountCard_MouseLeftButtonDown">
                                <StackPanel>
                                    <!-- Service Name & Status -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding ServiceName}" FontSize="15" FontWeight="Bold" Foreground="#DCDCDC"/>
                                    </StackPanel>
                                    
                                    <!-- Username -->
                                    <TextBlock Text="{Binding Username}" FontSize="13" Foreground="#808080" Margin="0,0,0,8"/>
                                    
                                    <!-- Password with buttons -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Background="#1E1E1E" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding DisplayPassword}" FontSize="12" Foreground="#DCDCDC" VerticalAlignment="Center"/>
                                        </Border>
                                        <Button Content="👁" Tag="{Binding}" Click="TogglePassword_Click"
                                                Background="Transparent" Foreground="#DCDCDC" BorderThickness="0"
                                                FontSize="14" Padding="4" Margin="0,0,4,0" Cursor="Hand" VerticalAlignment="Center"/>
                                        <Button Content="📋" Tag="{Binding}" Click="CopyPassword_Click"
                                                Background="Transparent" Foreground="#DCDCDC" BorderThickness="0"
                                                FontSize="14" Padding="4" Cursor="Hand" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    
                                    <!-- Tags -->
                                    <ItemsControl ItemsSource="{Binding Tags, Converter={StaticResource TagsToListConverter}}" Margin="0,0,0,8">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#007ACC" CornerRadius="10" Padding="8,4" Margin="0,0,6,4">
                                                    <TextBlock Text="{Binding}" Foreground="White" FontSize="11"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    
                                    <!-- Date Info -->
                                    <!-- <TextBlock FontSize="11" Foreground="#808080" Margin="0,0,0,6">
                                        <Run Text="수정일: "/><Run Text="{Binding ModifiedDateDisplay, Mode=OneWay}"/>
                                        <Run Text="  리셋일: "/><Run Text="{Binding ResetDateDisplay, Mode=OneWay}"/>
                                    </TextBlock> -->
                                    
                                    <!-- Notes -->
                                    <TextBlock Text="{Binding Notes}" FontSize="12" Foreground="#808080" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- Footer -->
            <TextBlock x:Name="AccountCountText" Grid.Row="4" Text="총 0개의 계정" 
                       Foreground="#808080" FontSize="12" Margin="0,15,0,0" HorizontalAlignment="Left"/>
        </Grid>
        
        <!-- Right Sidebar -->
        <Border Grid.Column="1" Background="#252526" CornerRadius="8" Padding="20">
            <StackPanel>
                <!-- Shortcuts Section -->
                <TextBlock Text="⌨️ 단축키" FontSize="16" FontWeight="Bold" Foreground="#DCDCDC" Margin="0,0,0,15"/>
                
                <StackPanel Margin="0,0,0,20">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#2D2D30" CornerRadius="4" Padding="6,4" Margin="0,0,8,0">
                            <TextBlock Text="Ctrl + N" FontSize="11" Foreground="#DCDCDC" FontFamily="Consolas"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="새 계정 추가" FontSize="12" Foreground="#808080" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#2D2D30" CornerRadius="4" Padding="6,4" Margin="0,0,8,0">
                            <TextBlock Text="Ctrl + F" FontSize="11" Foreground="#DCDCDC" FontFamily="Consolas"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="검색" FontSize="12" Foreground="#808080" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#2D2D30" CornerRadius="4" Padding="6,4" Margin="0,0,8,0">
                            <TextBlock Text="Ctrl + Shift + P" FontSize="11" Foreground="#DCDCDC" FontFamily="Consolas"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="창 열기" FontSize="12" Foreground="#808080" VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#2D2D30" CornerRadius="4" Padding="6,4" Margin="0,0,8,0">
                            <TextBlock Text="Esc" FontSize="11" Foreground="#DCDCDC" FontFamily="Consolas"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="닫기 / 취소" FontSize="12" Foreground="#808080" VerticalAlignment="Center"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#2D2D30" CornerRadius="4" Padding="6,4" Margin="0,0,8,0">
                            <TextBlock Text="Enter" FontSize="11" Foreground="#DCDCDC" FontFamily="Consolas"/>
                        </Border>
                        <TextBlock Grid.Column="1" Text="저장" FontSize="12" Foreground="#808080" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
                
                <!-- Status Section -->
                <TextBlock Text="📊 상태 표시" FontSize="16" FontWeight="Bold" Foreground="#DCDCDC" Margin="0,0,0,15"/>
                
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#4EC9B0" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="정상" FontSize="12" Foreground="#808080"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#CE9178" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="7일 이내 만료" FontSize="12" Foreground="#808080"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#F48771" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="만료 기한 초과" FontSize="12" Foreground="#808080"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
