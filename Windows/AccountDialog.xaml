<Window x:Class="PasswordProtector.Windows.AccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="계정 추가" Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header with Close Button -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="계정 정보" FontSize="20" FontWeight="Bold" Foreground="#DCDCDC" VerticalAlignment="Center"/>
            <Button Content="✕" Click="CloseButton_Click"
                    Background="Transparent" Foreground="#DCDCDC" BorderThickness="0"
                    FontSize="16" Padding="8" Cursor="Hand" HorizontalAlignment="Right"/>
        </Grid>
        
        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Service Name -->
                <TextBlock Text="서비스명" Foreground="#DCDCDC" FontSize="14" Margin="0,0,0,8"/>
                <TextBox Text="{Binding ServiceName, UpdateSourceTrigger=PropertyChanged}" 
                         Background="#2D2D30" Foreground="#DCDCDC" 
                         BorderBrush="#3F3F46" BorderThickness="1"
                         Padding="10,8" FontSize="14" Margin="0,0,0,15">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                
                <!-- Username -->
                <TextBlock Text="아이디" Foreground="#DCDCDC" FontSize="14" Margin="0,0,0,8"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                         Background="#2D2D30" Foreground="#DCDCDC" 
                         BorderBrush="#3F3F46" BorderThickness="1"
                         Padding="10,8" FontSize="14" Margin="0,0,0,15">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                
                <!-- Password -->
                <TextBlock Text="비밀번호" Foreground="#DCDCDC" FontSize="14" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <PasswordBox x:Name="PasswordBox" Grid.Column="0"
                                 Background="#2D2D30" Foreground="#DCDCDC" 
                                 BorderBrush="#3F3F46" BorderThickness="1"
                                 Padding="10,8" FontSize="14"
                                 PasswordChanged="PasswordBox_PasswordChanged">
                        <PasswordBox.Style>
                            <Style TargetType="PasswordBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="PasswordBox">
                                            <Border Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4">
                                                <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </PasswordBox.Style>
                    </PasswordBox>
                    
                    <TextBox x:Name="PasswordTextBox" Grid.Column="0" Visibility="Collapsed"
                             Background="#2D2D30" Foreground="#DCDCDC" 
                             BorderBrush="#3F3F46" BorderThickness="1"
                             Padding="10,8" FontSize="14"
                             TextChanged="PasswordTextBox_TextChanged">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4">
                                                <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    
                    <Button x:Name="TogglePasswordBtn" Grid.Column="1" Content="👁" Click="TogglePasswordButton_Click"
                            Background="Transparent" Foreground="#DCDCDC" BorderThickness="0"
                            FontSize="16" Padding="8" Margin="8,0,0,0" Cursor="Hand"/>
                </Grid>
                
                <!-- Reset Date -->
                <TextBlock Text="리셋 일자" Foreground="#DCDCDC" FontSize="14" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ResetDateTextBox" Grid.Column="0"
                             Background="#2D2D30" Foreground="#DCDCDC" 
                             BorderBrush="#3F3F46" BorderThickness="1"
                             Padding="10,8" FontSize="14" IsReadOnly="True"
                             MouseLeftButtonDown="ResetDateTextBox_MouseLeftButtonDown">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4">
                                                <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <Button Grid.Column="1" Content="📅" Click="SelectDateButton_Click"
                            Background="Transparent" Foreground="#DCDCDC" BorderThickness="0"
                            FontSize="16" Padding="8" Margin="8,0,0,0" Cursor="Hand"/>
                    <DatePicker x:Name="ResetDatePicker" Visibility="Collapsed" 
                                SelectedDateChanged="ResetDatePicker_SelectedDateChanged"/>
                </Grid>
                
                <!-- Tags -->
                <TextBlock Text="태그" Foreground="#DCDCDC" FontSize="14" Margin="0,0,0,8"/>
                <TextBox x:Name="TagTextBox" Margin="0,0,0,8"
                         Background="#2D2D30" Foreground="#DCDCDC" 
                         BorderBrush="#3F3F46" BorderThickness="1"
                         Padding="10,8" FontSize="14"
                         KeyDown="TagTextBox_KeyDown">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <TextBlock x:Name="PlaceholderText" 
                                                           Text="태그 입력 후 Enter"
                                                           Foreground="#808080" 
                                                           Padding="{TemplateBinding Padding}"
                                                           VerticalAlignment="Center"
                                                           IsHitTestVisible="False">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                
                <!-- Tag Chips -->
                <ItemsControl x:Name="TagChipsControl" Margin="0,0,0,15">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2D2D30" CornerRadius="4" Padding="8,4" Margin="0,0,6,6"
                                    BorderBrush="#3F3F46" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding}" Foreground="#DCDCDC" FontSize="12" VerticalAlignment="Center"/>
                                    <Button Content="✕" Tag="{Binding}" Click="RemoveTagButton_Click"
                                            Background="Transparent" Foreground="#808080" BorderThickness="0"
                                            FontSize="10" Padding="0" Margin="8,0,0,0" Cursor="Hand"
                                            VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <!-- Notes -->
                <TextBlock Text="비고" Foreground="#DCDCDC" FontSize="14" Margin="0,0,0,8"/>
                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" 
                         Background="#2D2D30" Foreground="#DCDCDC" 
                         BorderBrush="#3F3F46" BorderThickness="1"
                         Padding="10,8" FontSize="14" Margin="0,0,0,15"
                         Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Button x:Name="SaveButton" Grid.Column="0" Content="저장" Click="SaveButton_Click"
                    Background="#007ACC" Foreground="White" 
                    Padding="15,10" FontSize="14" BorderThickness="0"
                    Margin="0,0,8,0" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1C97EA"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            
            <Button Grid.Column="1" Content="취소" Click="CancelButton_Click"
                    Background="#3F3F46" Foreground="#DCDCDC" 
                    Padding="15,10" FontSize="14" BorderThickness="0"
                    Margin="8,0,0,0" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4F4F56"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>
